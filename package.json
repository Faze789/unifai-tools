{
  "name": "unifai-tools",
  "version": "1.0.0",
  "description": "Provider-agnostic AI tool calling for OpenAI, Anthropic, and Gemini. Define tools once with Zod, run them anywhere. Zero dependencies, full TypeScript inference, built-in agentic loop.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Faze789/unifai-tools.git"
  },
  "author": "Faze789",
  "homepage": "https://github.com/Faze789/unifai-tools#readme",
  "bugs": {
    "url": "https://github.com/Faze789/unifai-tools/issues"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.3",
    "zod": "^3.23.0"
  },
  "keywords": [
    "ai",
    "tools",
    "tool-calling",
    "function-calling",
    "openai",
    "anthropic",
    "gemini",
    "zod",
    "llm",
    "provider-agnostic",
    "agentic",
    "ai-tools",
    "ai-agents",
    "typescript",
    "json-schema"
  ],
  "license": "MIT"
}
